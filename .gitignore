# ═══════════════════════════════════════════════════════════════
#   ARYA InterviewMate — .gitignore
#   Keeps secrets, build artefacts, and junk out of Git.
# ═══════════════════════════════════════════════════════════════


# ── SECRETS — NEVER commit these ────────────────────────────────
.env
.env.local
.env.production
.env.staging
**/.env
**/.env.*
!**/.env.example


# ── PYTHON ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
venv/
env/
ENV/
.venv/
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
*.egg
dist/
build/
.eggs/
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml
*.cover


# ── DATABASE ──────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3


# ── NODE / REACT ──────────────────────────────────────────────────
node_modules/
frontend/build/
frontend/.pnp
frontend/.pnp.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
.eslintcache


# ── OS FILES ──────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini


# ── EDITORS & IDES ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
.project
.classpath
*.launch
*.sublime-project
*.sublime-workspace


# ── DOCKER ───────────────────────────────────────────────────────
*.log
docker-compose.override.yml


# ── MISC ──────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.cache/
*.zip
*.tar.gz
